{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "nixpacksConfig": {
    "providers": [
      "php",
      "node"
    ],
    "nodeVersion": "22"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "php artisan migrate --force && php artisan db:seed --force && heroku-php-apache2 public/"
  }
}